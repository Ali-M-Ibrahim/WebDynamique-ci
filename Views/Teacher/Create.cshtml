@model Teacher

<!DOCTYPE html>
<html>
<style>
    form {
        border-radius: 5px;
        background-color: #f2f2f2;
        padding: 20px;
    }

    label {
        display: block;
    }

    input, select, textarea {
        width: 100%;
        padding: 12px;
        margin: 8px 0;
        display: inline-block;
        border: 1px solid #ccc;
        border-radius: 4px;
        box-sizing: border-box;
    }

        input[type=submit] {
            width: 100%;
            background-color: #4CAF50;
            color: white;
            padding: 14px;
            margin: 8px 0;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }

            input[type=submit]:hover {
                background-color: #45a049;
            }
</style>
<body>

    <h2>Create Post Form</h2>

    <form method="post" asp-controller="Teacher" asp-action="Store">
        <div asp-validation-summary="All"></div>


        <label asp-for="Name">Name</label>
        <input asp-for="Name" type="text" id="Name" placeholder="Teacher Name..">
            <span asp-validation-for="Name"></span>


            <label asp-for="Salary">Salary</label>
            <input asp-for="Salary" type="text" id="Salary" placeholder="Teacher Salary..">
                <span asp-validation-for="Salary"></span>

  
                <input type="submit" value="Submit">
            </form>


            @section Scripts{
                <partial name="_ValidationScriptsPartial" />
            }

        </body>
    </html>


