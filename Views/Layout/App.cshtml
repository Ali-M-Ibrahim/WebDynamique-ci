@using USCJCI.Constant
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/USCJCI.styles.css" asp-append-version="true" />
    <style>

        h1{
  color:yellow;
        }
            body {
              margin: 0;
              font-family: Arial, Helvetica, sans-serif;
            }

            .topnav {
              overflow: hidden;
              background-color: #333;
            }

            .topnav a {
              float: left;
              color: #f2f2f2;
              text-align: center;
              padding: 14px 16px;
              text-decoration: none;
              font-size: 17px;
            }

            .topnav a:hover {
              background-color: #ddd;
              color: black;
            }

            .topnav a.active {
              background-color: #04AA6D;
              color: white;
            }

            .footer {
               position: fixed;
               left: 0;
               bottom: 0;
               width: 100%;
               background-color: black;
               color: white;
               text-align: center;
            }

    </style>
        @RenderSection("customCss", required:false)

</head>
<body>

    <div class="topnav">

        @if (User.IsInRole(Roles.Admin))
            {
          <a class="active" asp-controller="Product" asp-action="Index" >Product</a>

            }
         
        <a asp-controller="Post" asp-action="Index" >Post</a>

       <a  asp-controller="Student" asp-action="List" >Student</a>
    </div>


    @RenderSection("beforeContent", required:false)

    <div style="padding-left:16px">
      @RenderBody()
    </div>


    <div class="footer">
        <p>Footer</p>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
